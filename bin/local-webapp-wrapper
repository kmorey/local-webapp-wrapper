#!/bin/bash

set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"

while [[ -L "$SOURCE" ]]; do
  DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done

APP_DIR="$(cd "$(dirname "$SOURCE")/.." && pwd)"

exec "$APP_DIR/node_modules/.bin/electron" "$APP_DIR" "$@"
